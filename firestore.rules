rules_version = '2';

/* Ti-Services — règles de sécurité Firestore (bêta Phase 1)
   Modèle : comptes utilisateurs, dossiers artisans (validés par l'admin),
   demandes (« premier arrivé, premier servi »), messagerie à numéro masqué.
   L'admin est identifié par son e-mail (voir isAdmin — à remplacer par TON e-mail). */

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }
    function uid() { return request.auth.uid; }
    function email() { return request.auth.token.email; }

    // Admin unique Ti-Services (compte du domaine officiel).
    function isAdmin() {
      return signedIn() && email() in ['contact@ti-services.fr'];
    }

    function artisanDoc(id) {
      return get(/databases/$(database)/documents/artisans/$(id)).data;
    }
    function isValidArtisan() {
      return signedIn()
        && exists(/databases/$(database)/documents/artisans/$(uid()))
        && artisanDoc(uid()).status == 'valide';
    }

    // Jetons push de l'admin (FCM). La Cloud Function (Admin SDK) contourne
    // ces règles ; côté client seul l'admin lit/écrit ses jetons.
    match /adminTokens/{token} {
      allow read, write: if isAdmin();
    }

    // Catalogue partagé (services « Autre » ajoutés par l'admin) : lu par tous
    // (les clients doivent voir les services proposés), écrit par l'admin seul.
    match /settings/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Profils utilisateurs (client et/ou artisan)
    match /users/{userId} {
      allow read:   if isAdmin() || uid() == userId;
      allow create: if uid() == userId;
      // L'utilisateur met à jour sa fiche, MAIS l'accusé de lecture côté Ti-Services
      // (supReadAdmin) reste écrit par l'admin seul — sinon on pourrait feindre un « Lu ».
      allow update: if isAdmin()
                    || (uid() == userId
                        && request.resource.data.get('supReadAdmin', 0) == resource.data.get('supReadAdmin', 0));
      // Droit à l'effacement (RGPD) : l'utilisateur peut supprimer sa propre fiche.
      allow delete: if isAdmin() || uid() == userId;
    }

    // Dossiers artisans : créés par le prestataire (statut « attente » forcé),
    // le statut ne peut être changé que par l'admin.
    match /artisans/{artisanId} {
      allow read:   if isAdmin() || uid() == artisanId;
      // Le statut « fondateur » est attribué UNIQUEMENT par le serveur (Cloud Function
      // assignFounderSpot, via l'Admin SDK) : l'artisan ne peut ni se l'octroyer à la
      // création, ni le modifier ensuite — sinon on contournerait le quota des 12 places.
      allow create: if uid() == artisanId
                    && request.resource.data.status == 'attente'
                    && request.resource.data.get('founder', false) == false;
      allow update: if isAdmin()
                    || (uid() == artisanId
                        && request.resource.data.status == resource.data.status
                        && request.resource.data.get('founder', false) == resource.data.get('founder', false));
      // Droit à l'effacement (RGPD) : l'artisan peut supprimer son propre dossier.
      allow delete: if isAdmin() || uid() == artisanId;
    }

    // Dossiers conciergerie (mandataires) : créés par la structure (statut « attente »
    // forcé), le statut ne peut être changé que par l'admin. Les données
    // opérationnelles (clients, commandes, apport) sont écrites par la conciergerie
    // elle-même, sans jamais modifier son propre statut.
    match /concierges/{concId} {
      allow read:   if isAdmin() || uid() == concId;
      allow create: if uid() == concId
                    && request.resource.data.status == 'attente';
      // La conciergerie écrit ses données opérationnelles sans toucher à son statut ;
      // le marqueur de versement (retroPaid) ET la rétribution cumulée (earn) restent
      // écrits par le serveur/l'admin seuls — sinon une conciergerie pourrait s'afficher
      // « versée » à tort ou gonfler sa rétribution.
      allow update: if isAdmin()
                    || (uid() == concId
                        && request.resource.data.status == resource.data.status
                        && request.resource.data.get('retroPaid', '') == resource.data.get('retroPaid', '')
                        && request.resource.data.get('earn', 0) == resource.data.get('earn', 0));
      // Droit à l'effacement (RGPD) : la conciergerie peut supprimer son dossier.
      allow delete: if isAdmin() || uid() == concId;
    }

    // Registre comptable IMMUABLE (source de vérité). Écrit UNIQUEMENT par le serveur
    // (Cloud Function via l'Admin SDK, qui contourne ces règles) : aucun client ne peut
    // créer, modifier ni supprimer une écriture — donc rien ne se perd par bug ou manip.
    // Lecture : l'admin, plus la partie concernée (artisan / client) pour ses propres pièces.
    match /ledger/{entryId} {
      allow read:  if isAdmin()
                   || (signedIn() && resource.data.providerUid == uid())
                   || (signedIn() && resource.data.clientUid == uid());
      allow write: if false;
    }

    // Compteurs de numérotation des factures (séquence par intervenant). Écrits et lus
    // UNIQUEMENT par le serveur (Cloud Function / Admin SDK) : aucun accès client, pour
    // garantir l'unicité et la continuité de la numérotation.
    match /counters/{counterId} {
      allow read, write: if false;
    }

    // Demandes de prestation
    match /requests/{reqId} {
      function isClient()   { return signedIn() && resource.data.clientUid == uid(); }
      function isProvider() { return signedIn() && resource.data.providerUid == uid(); }

      // Ensemble des champs modifiés par une mise à jour.
      function changed() { return request.resource.data.diff(resource.data).affectedKeys(); }
      // Champs CALCULÉS PAR LE SERVEUR (settleCommission) : aucun client ne les écrit.
      // Le montant, la commission, le net, le n° de facture… viennent du registre serveur.
      function serverKeys() {
        return ['grossTotal','netAmount','commissionAmount','commissionPct','commissionBase',
                'saleInvoiceNo','commissionSettled','settledAt','molliePaymentId','molliePayout'];
      }
      // TERMES DU CONTRAT, figés dès l'acceptation : le tarif €/h, la majoration, l'unité,
      // le service et l'estimation convenue ne changent plus. Seule la DURÉE RÉELLE
      // (finalHours) peut bouger — déclarée par l'artisan, validée par le client.
      function contractKeys() {
        return ['rate','boost','unit','service','serviceName','duration','clientUid'];
      }

      // Lecture : client propriétaire, prestataire assigné, tout artisan validé
      // (pour découvrir les demandes ouvertes à accepter), admin.
      allow read: if isAdmin() || isClient() || isProvider() || isValidArtisan();

      // Création par le client, statut « pending », clientUid = soi-même.
      allow create: if signedIn()
                    && request.resource.data.clientUid == uid()
                    && request.resource.data.status == 'pending';

      // Mise à jour — chaque rôle ne peut toucher QUE ce qui le concerne, et JAMAIS
      // les champs financiers calculés par le serveur (intégrité de la commission).
      allow update: if isAdmin()

        // « Premier arrivé » : un artisan validé prend une demande encore pending.
        // Il s'assigne, sans toucher aux montants ni aux termes du contrat.
        // Demande DIRIGÉE (directed) : seul l'artisan précisément demandé peut la prendre.
        || (isValidArtisan()
            && resource.data.status == 'pending'
            && request.resource.data.status == 'accepted'
            && request.resource.data.providerUid == uid()
            && (resource.data.get('directed', false) == false
                || resource.data.get('preferredProviderUid', '') == uid())
            && !changed().hasAny(serverKeys())
            && !changed().hasAny(contractKeys()))

        // Demande DIRIGÉE déclinée : l'artisan PRÉCISÉMENT demandé refuse (pending -> declined).
        // Il ne s'assigne pas, ne touche ni aux montants ni au contrat. Le client décidera
        // ensuite d'ouvrir la demande à tous les artisans ou de l'annuler.
        || (isValidArtisan()
            && resource.data.status == 'pending'
            && resource.data.get('directed', false) == true
            && resource.data.get('preferredProviderUid', '') == uid()
            && request.resource.data.status == 'declined'
            && request.resource.data.get('providerUid', null) == null
            && !changed().hasAny(serverKeys())
            && !changed().hasAny(contractKeys()))

        // CLIENT propriétaire : il suit, VALIDE, conteste, annule ou relance (no-show).
        // Il ne fixe NI le tarif, NI la durée réelle (finalHours), NI les montants serveur.
        // Il peut au plus libérer le prestataire (providerUid -> null lors d'une relance).
        || (isClient()
            && !changed().hasAny(serverKeys())
            && !changed().hasAny(contractKeys())
            && !changed().hasAny(['finalHours'])
            && (request.resource.data.get('providerUid', null) == resource.data.get('providerUid', null)
                || request.resource.data.get('providerUid', null) == null))

        // PRESTATAIRE assigné : il fait avancer la mission et DÉCLARE la durée réelle
        // (finalHours) — le seul levier d'ajustement légitime. Jamais le tarif ni les
        // montants. Il peut se désister (providerUid -> null).
        || (isProvider()
            && !changed().hasAny(serverKeys())
            && !changed().hasAny(contractKeys())
            && (request.resource.data.get('providerUid', null) == resource.data.get('providerUid', null)
                || request.resource.data.get('providerUid', null) == null));

      // Le client ne peut supprimer que SA demande encore « pending » (annulation avant
      // acceptation). Une demande acceptée / en cours / réglée est une pièce comptable :
      // seul l'admin peut l'effacer (RGPD). Les commissions restent de toute façon dans
      // le registre immuable `ledger`, hors de portée du client.
      allow delete: if isAdmin() || (isClient() && (resource.data.status == 'pending' || resource.data.status == 'declined'));

      // Messagerie : réservée au client, au prestataire assigné et à l'admin.
      match /messages/{msgId} {
        function parent() {
          return get(/databases/$(database)/documents/requests/$(reqId)).data;
        }
        allow read, create: if isAdmin()
          || parent().clientUid == uid()
          || parent().providerUid == uid();
      }

      // Détails privés (adresse exacte, GPS, accès) : créés par le client,
      // lisibles seulement par le client, l'artisan ASSIGNÉ et l'admin
      // (jamais par les artisans qui parcourent les demandes ouvertes).
      match /private/{doc} {
        function parent() {
          return get(/databases/$(database)/documents/requests/$(reqId)).data;
        }
        allow create: if signedIn() && parent().clientUid == uid();
        allow read:   if isAdmin() || parent().clientUid == uid() || parent().providerUid == uid();
        allow update, delete: if isAdmin() || parent().clientUid == uid();
      }
    }
  }
}
